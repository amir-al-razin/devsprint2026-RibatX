# Copy this to .env and fill in values before running locally.
# Never commit the actual .env file.

# ── Shared ────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string

# ── Postgres connection strings (per service) ─────────────────────────────────
IDENTITY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/identity_db
GATEWAY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/order_db
STOCK_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stock_db
KITCHEN_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kitchen_db
NOTIFY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/notify_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Service ports (for local dev outside Docker) ──────────────────────────────
IDENTITY_PORT=3001
GATEWAY_PORT=3000
STOCK_PORT=3002
KITCHEN_PORT=3003
NOTIFICATION_PORT=3004
WEB_PORT=4000

# ── CORS origin (set to frontend URL) ─────────────────────────────────────────
CORS_ORIGIN=http://localhost:4000
