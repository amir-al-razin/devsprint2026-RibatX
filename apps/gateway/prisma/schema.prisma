// Prisma schema for the gateway service
// Uses PostgreSQL for durable order storage

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Order {
  id        String   @id          // Same as orderId (e.g. ORD-<uuid>)
  traceId   String
  status    String
  studentId String
  itemId    String

  createdAt DateTime @default(now())
  updatedAt DateTime?

  // Timeline of state transitions for this order, stored as JSON
  timeline  Json
}

